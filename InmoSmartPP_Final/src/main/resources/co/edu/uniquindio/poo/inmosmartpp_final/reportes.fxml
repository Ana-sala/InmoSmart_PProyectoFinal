<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<AnchorPane prefWidth="700" prefHeight="550" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.uniquindio.poo.inmosmartpp_final.viewController.ReporteViewController">
    <VBox AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10" AnchorPane.bottomAnchor="10" spacing="12">
        <padding><Insets top="10" left="10" right="10" bottom="10"/></padding>
        <Label text="Reportes del Sistema" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

        <FlowPane hgap="10" vgap="10">
            <Button text="Inmuebles vendidos" onAction="#onInmueblesMasVendidos"/>
            <Button text="Compradores activos" onAction="#onCompradoresMasActivos"/>
            <Button text="Vendedores top" onAction="#onVendedoresMasPropiedades"/>
            <Button text="Ciudad con mayor demanda" onAction="#onCiudadMayorDemanda"/>
        </FlowPane>

        <Separator/>

        <Label fx:id="lblTitulo" text="Selecciona un reporte"
               style="-fx-font-size: 14; -fx-font-weight: bold;"/>

        <Label fx:id="lblCiudad" text=""
               style="-fx-font-size: 16;" visible="false"/>

        <!-- Tabla inmuebles vendidos -->
        <TableView fx:id="tblInmuebles" VBox.vgrow="ALWAYS" visible="false">
            <columns>
                <TableColumn fx:id="colCodigo" text="Codigo" prefWidth="100"/>
                <TableColumn fx:id="colTipo" text="Tipo" prefWidth="120"/>
                <TableColumn fx:id="colCiudad" text="Ciudad" prefWidth="150"/>
                <TableColumn fx:id="colPrecio" text="Precio" prefWidth="150"/>
            </columns>
        </TableView>

        <!-- Tabla compradores activos -->
        <TableView fx:id="tblCompradores" VBox.vgrow="ALWAYS" visible="false">
            <columns>
                <TableColumn fx:id="colNombreC" text="Nombre" prefWidth="160"/>
                <TableColumn fx:id="colIdentC" text="Identificacion" prefWidth="130"/>
                <TableColumn fx:id="colPuntosC" text="Puntos" prefWidth="80"/>
                <TableColumn fx:id="colRangoC" text="Rango" prefWidth="150"/>
            </columns>
        </TableView>

        <!-- Tabla vendedores top -->
        <TableView fx:id="tblVendedores" VBox.vgrow="ALWAYS" visible="false">
            <columns>
                <TableColumn fx:id="colNombreV" text="Nombre" prefWidth="160"/>
                <TableColumn fx:id="colIdentV" text="Identificacion" prefWidth="130"/>
                <TableColumn fx:id="colPropiedadesV" text="Propiedades" prefWidth="100"/>
                <TableColumn fx:id="colRangoV" text="Rango" prefWidth="130"/>
            </columns>
        </TableView>

        <Button text="&lt;- Volver" onAction="#onVolver"/>
    </VBox>
</AnchorPane>