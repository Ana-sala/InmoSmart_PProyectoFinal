<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<AnchorPane prefWidth="750" prefHeight="650" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.uniquindio.poo.inmosmartpp_final.viewController.InmuebleViewController">
    <ScrollPane fitToWidth="true"
                AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
                AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">
        <VBox spacing="10">
            <padding><Insets top="10" left="10" right="10" bottom="10"/></padding>
            <Label text="Gestión de Inmuebles" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
            <GridPane hgap="10" vgap="8">
                <Label text="Código:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtCodigo" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"/>
                <Label text="Tipo:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbTipo" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="200"/>
                <Label text="Dirección:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtDireccion" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                <Label text="Ciudad:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="txtCiudad" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                <Label text="Área (m²):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="txtArea" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                <Label text="Precio:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextField fx:id="txtPrecio" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                <Label text="Vendedor:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbVendedor" GridPane.rowIndex="6" GridPane.columnIndex="1" prefWidth="200"/>
                <Label text="Descripción:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                <TextField fx:id="txtDescripcion" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
            </GridPane>
            <HBox spacing="10">
                <Button text="Publicar" onAction="#onPublicar"/>
                <Button text="Limpiar" onAction="#onLimpiar"/>
                <Button text="&lt;- Volver" onAction="#onVolver"/>
            </HBox>

            <Separator/>
            <Label text="Buscar Inmuebles" style="-fx-font-weight: bold;"/>
            <GridPane hgap="10" vgap="8">
                <Label text="Ciudad:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtBuscarCiudad" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="150"/>
                <Label text="Tipo:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <ComboBox fx:id="cmbBuscarTipo" GridPane.rowIndex="0" GridPane.columnIndex="3" prefWidth="130"/>
                <Label text="Precio mín:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtPrecioMin" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="150"/>
                <Label text="Precio máx:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <TextField fx:id="txtPrecioMax" GridPane.rowIndex="1" GridPane.columnIndex="3" prefWidth="130"/>
                <Label text="Área mín:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtAreaMin" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="150"/>
            </GridPane>
            <HBox spacing="10">
                <Button text="Buscar" onAction="#onBuscar"/>
                <Button text="Mostrar todos" onAction="#onMostrarTodos"/>
            </HBox>

            <TableView fx:id="tblInmuebles" prefHeight="200">
                <columns>
                    <TableColumn fx:id="colCodigo" text="Código" prefWidth="100"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="100"/>
                    <TableColumn fx:id="colCiudad" text="Ciudad" prefWidth="120"/>
                    <TableColumn fx:id="colPrecio" text="Precio" prefWidth="150"/>
                    <TableColumn fx:id="colArea" text="Área (m²)" prefWidth="100"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </ScrollPane>
</AnchorPane>